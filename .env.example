# === BASE DE DATOS ===
DB_HOST=localhost
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=rentitp

# === PUERTOS ===
PORT=8080
SSL_PORT=3443

# === FRONTEND ===
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# === FIREBASE ===
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# === JWT ===
JWT_SECRET=your_jwt_secret_key_here

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# === GITHUB OAUTH ===
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# === IDRIVE E2 (S3 Compatible) ===
IDRIVE_ACCESS_KEY=your_idrive_access_key
IDRIVE_SECRET_KEY=your_idrive_secret_key
IDRIVE_ENDPOINT=https://s3.ap-south-1.idrivee2.com
IDRIVE_REGION=ap-south-1
IDRIVE_BUCKET=your_idrive_bucket_name

# === SIGNED URL CONFIGURATION ===
# Tiempo de expiración de URLs firmadas en segundos (7 días = 604800)
URL_EXPIRATION_SECONDS=604800

# === FILE UPLOAD CONFIGURATION ===
# Tipos MIME permitidos para imágenes (separados por coma)
ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/svg+xml

# Tamaño máximo de archivo en bytes (10 MB = 10485760)
MAX_FILE_SIZE=10485760

# Número máximo de archivos por upload
MAX_FILES=10

# === NODE ENVIRONMENT ===
NODE_ENV=development
